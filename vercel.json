{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.dollpictures.in" }],
      "destination": "https://dollpictures.in/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://photography-cms-backend.onrender.com/api/sitemap.xml"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin(?:/.*)?", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
