# Backend API base URL (includes /api prefix).
# Used at runtime by the app. Also used at build time (`prebuild`) to write
# host proxy rules so https://yoursite/sitemap.xml → {VITE_API_URL}/sitemap.xml.
# Set this in Netlify/Vercel production env as well.
VITE_API_URL=http://localhost:3001/api

# Public site origin (no trailing slash). Used at build time for robots.txt,
# prerender canonicals/OG URLs, and runtime SEO absolute URLs.
# Set this in Netlify/Vercel production env as well.
VITE_SITE_URL=https://dollpictures.in

# Google Analytics 4 measurement ID (production only)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID (production only; leave blank to disable)
VITE_META_PIXEL_ID=
